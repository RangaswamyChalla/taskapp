# ======================================================
# .env.example — Generated by AIDEN Deployer v2
# Copy to .env — never commit .env to version control
# ======================================================

# ── Application ──────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://appuser:changeme@localhost:5432/taskapp

POSTGRES_DB=taskapp
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_use_strong_password

# ── Authentication ───────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=replace_with_64_byte_random_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend ─────────────────────────────────────────
REACT_APP_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ── Email (notifications) ────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.your_sendgrid_key_here
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=TaskApp

# ── Observability ────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=https://your_dsn@sentry.io/project_id